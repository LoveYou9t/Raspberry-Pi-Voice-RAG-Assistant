APP_HOST=0.0.0.0
APP_PORT=8000
WS_PATH=/ws/audio-stream

LOG_LEVEL=INFO

OLLAMA_HOST=http://ollama_server:11434
LLM_MODEL=llama3.2:1b
LLM_NUM_CTX=4096
LLM_TEMPERATURE=0.3
LLM_TOP_K=40

SAMPLE_RATE=16000
AUDIO_CHUNK_SECONDS=1.0

VAD_MIN_SILENCE_MS=500
VAD_THRESHOLD=0.4

RAG_TOP_K=3
KNOWLEDGE_DIR=/app/knowledge_base
LANCEDB_DIR=/app/lancedb_data
LANCEDB_TABLE=knowledge_base_vectors
VECTOR_DIM=384

PIPER_BIN=piper
PIPER_MODEL=zh_CN-huayan-medium.onnx
PIPER_CHUNK_SIZE=4096
PIPER_USE_MOCK_ON_MISSING=1
