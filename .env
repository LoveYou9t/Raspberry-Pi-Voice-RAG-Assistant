APP_HOST=0.0.0.0
APP_PORT=8000
WS_PATH=/ws/audio-stream

LOG_LEVEL=INFO

PIP_INDEX_URL=https://pypi.tuna.tsinghua.edu.cn/simple
PIP_FALLBACK_INDEX_URL=https://pypi.org/simple

OLLAMA_HOST=http://ollama_server:11434
LLM_MODEL=llama3.2:3b
LLM_NUM_CTX=4096
LLM_TEMPERATURE=0.3
LLM_TOP_K=40

STT_MODEL=tiny
STT_PREWARM_STRICT=0
STT_PREWARM_STATUS_FILE=/app/model_cache/stt_prewarm_status.json

SAMPLE_RATE=16000
AUDIO_CHUNK_SECONDS=1.0

VAD_MIN_SILENCE_MS=500
VAD_THRESHOLD=0.4

RAG_TOP_K=3
KNOWLEDGE_DIR=/app/knowledge_base
LANCEDB_DIR=/app/lancedb_data
LANCEDB_TABLE=knowledge_base_vectors
VECTOR_DIM=384

PIPER_BIN=piper
PIPER_MODEL=/app/piper_cache/zh_CN-huayan-medium.onnx
PIPER_MODEL_URL=https://huggingface.co/rhasspy/piper-voices/resolve/main/zh/zh_CN/huayan/medium/zh_CN-huayan-medium.onnx
PIPER_MODEL_FALLBACK_URLS=https://hf-mirror.com/rhasspy/piper-voices/resolve/main/zh/zh_CN/huayan/medium/zh_CN-huayan-medium.onnx
PIPER_MODEL_CONFIG_URL=https://huggingface.co/rhasspy/piper-voices/resolve/main/zh/zh_CN/huayan/medium/zh_CN-huayan-medium.onnx.json
PIPER_MODEL_CONFIG_FALLBACK_URLS=https://hf-mirror.com/rhasspy/piper-voices/resolve/main/zh/zh_CN/huayan/medium/zh_CN-huayan-medium.onnx.json
PIPER_DOWNLOAD_TRUST_ENV=0
PIPER_DOWNLOAD_LOCAL_ADDRESS=0.0.0.0
PIPER_CHUNK_SIZE=4096
PIPER_USE_MOCK_ON_MISSING=0
PIPER_PREWARM_STRICT=0
PIPER_PREWARM_STATUS_FILE=/app/piper_cache/piper_prewarm_status.json
